# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv-bench/
ENV/
env/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# MPI/HPC
*.out
*.err
slurm-*.out

# Logs
*.log

# Test outputs
*.json
!benchmarks/*.json
!benchmarks/**/*.json

# Virtual environments in subdirectories
pdmrg/venv/
pdmrg-opt/venv/
a2dmrg/venv/

# Exclude development artifacts in subdirectories
**/SESSION_*.txt
**/.bash_profile
**/.bashrc
**/.profile
**/.zprofile
**/.zshrc
**/.gitconfig
**/.gitmodules
**/.ripgreprc
**/.idea
**/.vscode
**/.claude
**/.claude_settings.json
# Allow repo-root .claude/ (shared agents, commands, hooks, settings) to be
# tracked, but keep local-only overrides out.
!/.claude/
!/.claude/**
/.claude/settings.local.json
/.claude/**/settings.local.json
**/.mcp.json
**/HEAD
**/hooks
**/refs
**/objects
**/config
# Re-allow the Path B hook script (matched by **/hooks above, but needs to be tracked).
!/.claude/hooks/
!/.claude/hooks/**
**/*.egg-info/
**/.pytest_cache/
**/venv/

# LLM session staging areas — prevent recurrence of _diagnostic_logs/ escape
_diagnostic_logs/
